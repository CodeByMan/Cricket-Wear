# Copy this file to backend/config/config.env
# Maintainer / owner / developer: Muhammad Ali Nawaz

# Database: use MongoDB Atlas or local MongoDB
MONGO_URI=mongodb://localhost:27017/cricket-wear-store
# DB_LINK=mongodb://localhost:27017/cricket-wear-store

# JWT
JWT_SECRET=SpecialPassword123!
JWT_EXPIRE=7d
COOKIE_EXPIRE=7

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_REQUESTS=false

# Cloudinary - optional during local development
# Leave blank until you are ready to upload real images.
CLOUDINARY_NAME=
API_KEY=
API_SECRET=

# Stripe - optional during local development
# Leave blank until you are ready to enable payments.
STRIPE_SECRET_KEY=
STRIPE_API_KEY=

# Email - optional during local development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SERVICE=gmail
SMTP_MAIL=
SMTP_PASSWORD=
