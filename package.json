{
  "name": "cricket-wear-store",
  "version": "2.0.0",
  "description": "Cricket Wear Store MERN e-commerce platform upgraded and maintained by Muhammad Ali Nawaz.",
  "main": "backend/server.js",
  "author": "Muhammad Ali Nawaz",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0 <=22.x"
  },
  "scripts": {
    "start": "node backend/server.js",
    "server": "node backend/server.js",
    "dev:server": "nodemon backend/server.js",
    "start-client": "npm start --prefix frontend",
    "dev:client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm run build --prefix frontend",
    "seed": "node backend/seeder/seed.js --import",
    "seed:destroy": "node backend/seeder/seed.js --destroy"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.3.0",
    "cloudinary": "^2.5.1",
    "concurrently": "^10.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "nodemailer": "^9.0.1",
    "stripe": "^17.6.0",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "overrides": {
    "picomatch": "^2.3.2"
  }
}
